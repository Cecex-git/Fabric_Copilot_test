model Games
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_ProTooling = ["MCP-PBIModeling"]

ref table Games

ref table Platforms

relationship 'Games-Platforms'
	fromColumn: Games.Platform
	toColumn: Platforms.Platform
